From 8d30295e12f4ceae8d653c35f10e03645a964526 Mon Sep 17 00:00:00 2001
From: Thomas Arcila <134677+tarcila@users.noreply.github.com>
Date: Mon, 20 Apr 2026 10:22:45 -0400
Subject: [PATCH] anari_viewer: expose pixel density and set ImGui
 DisplayFramebufferScale

---
 src/anari_viewer/Application.cpp | 11 +++++++++--
 src/anari_viewer/Application.h   |  1 +
 2 files changed, 10 insertions(+), 2 deletions(-)

diff --git a/src/anari_viewer/Application.cpp b/src/anari_viewer/Application.cpp
index 2d2828b63d..0197b3dce3 100644
--- a/src/anari_viewer/Application.cpp
+++ b/src/anari_viewer/Application.cpp
@@ -22,6 +22,7 @@ struct AppImpl
 {
   SDL_Window *sdl_window{nullptr};
   SDL_Renderer *sdl_renderer{nullptr};
+  float pixel_density{1.f};
   int width{0};
   int height{0};
   bool windowResized{true};
@@ -82,6 +83,11 @@ SDL_Window *Application::sdlWindow()
   return m_impl->sdl_window;
 }
 
+float Application::pixelDensity() const
+{
+  return m_impl->pixel_density;
+}
+
 Uint32 Application::sdlWindowFlags() const
 {
   return SDL_WINDOW_OPENGL | SDL_WINDOW_RESIZABLE | SDL_WINDOW_HIDDEN
@@ -211,8 +217,8 @@ void AppImpl::init(Uint32 window_flags)
   SDL_ShowWindow(sdl_window);
 
   // Set render scale to match pixel density for HiDPI/Retina displays.
-  float scale = SDL_GetWindowPixelDensity(sdl_window);
-  SDL_SetRenderScale(sdl_renderer, scale, scale);
+  pixel_density = SDL_GetWindowPixelDensity(sdl_window);
+  SDL_SetRenderScale(sdl_renderer, pixel_density, pixel_density);
 
   ImGui::CreateContext();
   ImGui::StyleColorsDark();
@@ -223,6 +229,7 @@ void AppImpl::init(Uint32 window_flags)
   ImGuiIO &io = ImGui::GetIO();
   io.ConfigFlags |= ImGuiConfigFlags_NavEnableKeyboard;
   io.ConfigFlags |= ImGuiConfigFlags_DockingEnable;
+  io.DisplayFramebufferScale = ImVec2(pixel_density, pixel_density);
   ImGui::StyleColorsDark();
 
   ImGuiStyle &style = ImGui::GetStyle();
diff --git a/src/anari_viewer/Application.h b/src/anari_viewer/Application.h
index 3541377de7..e25e8ac47a 100644
--- a/src/anari_viewer/Application.h
+++ b/src/anari_viewer/Application.h
@@ -45,6 +45,7 @@ class Application
 
   SDL_Renderer* sdlRenderer();
   SDL_Window* sdlWindow();
+  float pixelDensity() const;
 
   // Start the application run loop
   void run(int width, int height, const char *name);
-- 
2.51.2

