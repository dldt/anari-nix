# Hand-written package config for the Nix `dev` output of TSD.
# Exposes one aggregate IMPORTED target, tsd::tsd. The static archives are
# wrapped in a linker group so static link order does not matter.
include(CMakeFindDependencyMacro)
find_dependency(anari)
find_dependency(fmt)
@TSD_EXTRA_FIND_DEPS@

get_filename_component(_tsd_root "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)
set(_tsd_inc "${_tsd_root}/include")
file(GLOB _tsd_libs "${_tsd_root}/lib/libtsd_*.a")

add_library(tsd::tsd INTERFACE IMPORTED)
target_include_directories(tsd::tsd INTERFACE "${_tsd_inc}")
target_link_libraries(tsd::tsd INTERFACE
  "-Wl,--start-group" ${_tsd_libs} "-Wl,--end-group"
  anari::anari anari::helium fmt::fmt@TSD_EXTRA_LINK_LIBS@)
