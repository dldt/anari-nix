From 8672c6e02c959da9481a99427d37149710820f11 Mon Sep 17 00:00:00 2001
From: Thomas Arcila <134677+tarcila@users.noreply.github.com>
Date: Thu, 16 Apr 2026 18:54:00 -0400
Subject: [PATCH 6/6] Let USD find OpenSubdiv in config mode

Nixpkgs ships OpenSubdiv with a CMake config package, so keep USD's
find_dependency(OpenSubdiv CONFIG) enabled; otherwise the exported
OpenSubdiv::osd{CPU,GPU} targets referenced by pxrTargets are undefined
and flatten_and_cleanup_targets fails.
---
 UsdBridge/CMakeLists.txt | 6 ------
 1 file changed, 6 deletions(-)

diff --git a/UsdBridge/CMakeLists.txt b/UsdBridge/CMakeLists.txt
index 97365ad..c65a878 100644
--- a/UsdBridge/CMakeLists.txt
+++ b/UsdBridge/CMakeLists.txt
@@ -111,12 +111,6 @@ if(${USD_DEVICE_RENDERING_ENABLED} AND NOT TARGET opensubdiv::opensubdiv)
   )
 endif()
 
-# pxrConfig.cmake performs a find_dependency(OpenSubdiv CONFIG), but some USD
-# distributions only ship the prebuilt OpenSubdiv libs (e.g. osdCPU/osdGPU)
-# without a CMake config package. The OpenSubdiv symbols are already provided
-# through pxrTargets, so disable USD's config-mode lookup, as is done for TBB above.
-set(PXR_FIND_OPENSUBDIV_IN_CONFIG OFF)
-
 # Search in config mode (USD will now skip TBB finding and use the targets defined above)
 find_package(X11)
 find_package(OpenGL)
